{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "query-manifest.json",
  "title": "LOLVPN query manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "title",
    "description",
    "tags",
    "platforms",
    "tables",
    "implementations"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "stable slug for api and permalinks"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["vendor", "product"],
        "properties": {
          "vendor": { "type": "string" },
          "product": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "tables": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "mitre": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^T[0-9]{4}(\\.[0-9]{3})?$"
      }
    },
    "performanceNotes": { "type": "string" },
    "falsePositives": { "type": "string" },
    "references": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "license": { "type": "string" },
    "author": { "type": "string" },
    "implementations": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "kql": { "$ref": "#/definitions/languageImpl" },
        "spl": { "$ref": "#/definitions/languageImpl" },
        "sigma": { "$ref": "#/definitions/languageImpl" }
      }
    }
  },
  "definitions": {
    "languageImpl": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "description": "path relative to this query directory"
        },
        "notes": { "type": "string" }
      }
    }
  }
}
